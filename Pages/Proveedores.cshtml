@page
@model ProveedoresModel
@{
    ViewData["Title"] = "Proveedores";
}

<div class="estilo-inventario">
    <ul class="nav menu">
        <li class="nav-item">
            <button class="nav-link" data-bs-toggle="modal" data-bs-target="#modal-sesion">
                <img class="cuenta-busqueda" src="/img/usuarioIcono2.png" alt="">
            </button>

            <div class="modal" tabindex="-1" id="modal-sesion">
                <div class="modal-dialog">
                    <div class="modal-content">
                        <div class="modal-header">
                            <h5 class="modal-title">Información de Usuario</h5>

                            <button type="button"
                                    class="btn-close"
                                    data-bs-dismiss="modal"
                                    aria-label="Close">
                            </button>
                        </div>

                        <div class="modal-body">
                            @if (Model.UsuarioActual != null)
                            {
                                <p>Nombre: @Model.UsuarioActual.Nombre</p>
                                <p>Teléfono: @Model.UsuarioActual.Telefono</p>
                                <p>Rol: @Model.UsuarioActual.Rol</p>
                            }
                        </div>

                        <div class="modal-footer">
                            <button type="button"
                                    class="btn btn-secondary"
                                    data-bs-dismiss="modal">
                                Aceptar
                            </button>

                            <a asp-page="/Index" asp-page-handler="CerrarSesion" class="btn btn-primary">
                                Cerrar sesión
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </li>

        <li class="nav-item">
            <a class="nav-link" asp-page="/Administrador">
                <img title="Dashboard" class="img-menu" src="/img/dashboard.svg" alt="">
            </a>
        </li>

        <li class="nav-item">
            <a class="nav-link seleccionado" asp-page="/Inventario">
                <img title="Inventario" class="img-menu" src="/img/barcode-solid.svg" alt="">
            </a>
        </li>

        <li class="nav-item">
            <a class="nav-link" asp-page="/Tiendas">
                <img title="Tiendas" class="img-menu" src="/img/store.svg" alt="">
            </a>
        </li>

        <li class="nav-item">
            <a class="nav-link" asp-page="/Historial">
                <img title="Historial" class="img-menu" src="/img/historial.svg" alt="">
            </a>
        </li>
    </ul>

    <div class="inventario">
        <div class="encabezado">
            <div class="fila-titulo">
                <div class="regreso">
                    <a asp-page="/Inventario" class="btn-regreso">
                        <img src="/img/arrow-left-solid.svg" alt="">
                    </a>
                </div>

                <div class="titulo">Proveedores</div>
            </div>

            <div class="fila">
                <form method="post" asp-page-handler="Busqueda" class="busqueda">
                    <input class="barra-busqueda"
                           type="text"
                           placeholder="Buscar por nombre, teléfono o correo"
                           name="ParametroDeBusqueda"
                           value="@Model.ParametroDeBusqueda">

                    <button type="submit" class="btn-busqueda-lupa">
                        <img src="/img/lupa.png" alt="" class="img-lupa">
                    </button>
                </form>

                <div class="info-encabezado">
                    <button class="elemento-info-encabezado" data-bs-toggle="modal" data-bs-target="#modal-proveedor">
                        Nuevo proveedor
                        <img class="btn-inventario" src="/img/agregar.svg" alt="">
                    </button>

                    <div class="modal" tabindex="-1" id="modal-proveedor" data-bs-backdrop="static">
                        <div class="modal-dialog">
                            <div class="modal-content">
                                <div class="modal-header">
                                    <h5 class="modal-title">Ingrese la información del proveedor</h5>
                                </div>

                                <form method="post" asp-page-handler="Agregar">
                                    <div class="modal-body">
                                        <div class="info-tienda">
                                            Nombre:
                                            <input name="Nombre"
                                                   class="form-control"
                                                   maxlength="50"
                                                   required>
                                        </div>

                                        <div class="info-tienda">
                                            Teléfono:
                                            <input type="tel"
                                                   name="Telefono"
                                                   class="form-control"
                                                   required
                                                   pattern="^\d{10}$"
                                                   maxlength="10"
                                                   title="El teléfono debe contener exactamente 10 dígitos numéricos."
                                                   placeholder="10 dígitos">
                                        </div>

                                        <div class="info-tienda">
                                            Correo:
                                            <input name="Correo"
                                                   type="email"
                                                   maxlength="30"
                                                   class="form-control"
                                                   required
                                                   pattern="^[^@@\s]+@@[^@@\s]+\.[^@@\s]+$"
                                                   title="Ingresa un correo válido, por ejemplo: proveedor@correo.com">
                                        </div>
                                    </div>

                                    <div class="modal-footer">
                                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
                                            Cancelar
                                        </button>

                                        <button type="submit" class="btn btn-primary">
                                            Registrar proveedor
                                        </button>
                                    </div>
                                </form>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="tablas">
            <div class="contenedor-tabla">
                <div class="tabla-productos orden-correcto">
                    <table class="table table-dark table-striped tabla-menor-mayor" data-empty="No se encontraron proveedores">
                        <thead>
                            <tr>
                                <th scope="col">Nombre</th>
                                <th scope="col">Teléfono</th>
                                <th scope="col">Correo</th>
                                <th scope="col">Estado</th>
                                <th scope="col" class="no-ordenar">
                                    <span class="invisible">Editar</span>
                                </th>
                            </tr>
                        </thead>

                        <tbody>
                            @foreach (var proveedor in Model.Proveedores)
                            {
                                <tr>
                                    <td>@proveedor.Nombre</td>
                                    <td>@proveedor.Telefono</td>
                                    <td>@proveedor.Correo</td>

                                    <td>
                                        @if (proveedor.Activo == true)
                                        {
                                            @:<p class="text-success">Activo</p>
                                        }
                                        else
                                        {
                                            @:<p class="text-danger">Inactivo</p>
                                        }
                                    </td>

                                    <td>
                                        <button class="btn-detalles-tienda"
                                                data-bs-toggle="modal"
                                                data-bs-target="#modal-editar-proveedor-@proveedor.ProveedorId">
                                            Editar
                                            <img class="btn-inventario" src="/img/editar.svg" alt="">
                                        </button>

                                        <div class="modal" tabindex="-1" id="modal-editar-proveedor-@proveedor.ProveedorId"
                                             data-bs-backdrop="static">
                                            <div class="modal-dialog">
                                                <div class="modal-content">
                                                    <div class="modal-header">
                                                        <h5 class="modal-title">Información del proveedor</h5>

                                                        <button type="button"
                                                                class="btn-close"
                                                                data-bs-dismiss="modal"
                                                                aria-label="Close">
                                                        </button>
                                                    </div>

                                                    <form method="post" asp-page-handler="Editar">
                                                        <input type="hidden" name="ProveedorId" value="@proveedor.ProveedorId">

                                                        <div class="modal-body">
                                                            <div class="info-tienda">
                                                                Id:
                                                                <input type="text"
                                                                       class="form-control"
                                                                       value="@proveedor.ProveedorId"
                                                                       disabled>
                                                            </div>

                                                            <div class="info-tienda">
                                                                Nombre:
                                                                <input type="text"
                                                                       class="form-control"
                                                                       name="Nombre"
                                                                       maxlength="50"
                                                                       value="@proveedor.Nombre"
                                                                       required>
                                                            </div>

                                                            <div class="info-tienda">
                                                                Teléfono:
                                                                <input type="tel"
                                                                       class="form-control"
                                                                       name="Telefono"
                                                                       value="@proveedor.Telefono"
                                                                       required
                                                                       pattern="^\d{10}$"
                                                                       maxlength="10"
                                                                       title="El teléfono debe contener exactamente 10 dígitos numéricos.">
                                                            </div>

                                                            <div class="info-tienda">
                                                                Correo:
                                                                <input name="Correo"
                                                                       value="@proveedor.Correo"
                                                                       type="email"
                                                                       maxlength="30"
                                                                       class="form-control"
                                                                       required
                                                                       pattern="^[^@@\s]+@@[^@@\s]+\.[^@@\s]+$"
                                                                       title="Ingresa un correo válido, por ejemplo: proveedor@correo.com">
                                                            </div>

                                                            <div class="info-tienda">
                                                                Estado:
                                                                <select name="Activo" class="form-control form-select">
                                                                    @if (proveedor.Activo == true)
                                                                    {
                                                                        <option value="true" selected hidden>Activo</option>
                                                                        <option value="false">Inactivo</option>
                                                                    }
                                                                    else
                                                                    {
                                                                        <option value="true">Activo</option>
                                                                        <option value="false" selected hidden>Inactivo</option>
                                                                    }
                                                                </select>
                                                            </div>
                                                        </div>

                                                        <div class="modal-footer">
                                                            <button type="button"
                                                                    class="btn btn-secondary"
                                                                    data-bs-dismiss="modal">
                                                                Cancelar
                                                            </button>

                                                            <button type="button"
                                                                    class="btn btn-danger"
                                                                    data-bs-dismiss="modal"
                                                                    data-bs-toggle="modal"
                                                                    data-bs-target="#modal-confirmar-eliminar-@proveedor.ProveedorId">
                                                                Borrar
                                                            </button>

                                                            <button type="submit" class="btn btn-primary">
                                                                Guardar cambios
                                                            </button>
                                                        </div>
                                                    </form>
                                                </div>
                                            </div>
                                        </div>

                                        <div class="modal fade" id="modal-confirmar-eliminar-@proveedor.ProveedorId" tabindex="-1" data-bs-backdrop="static">
                                            <div class="modal-dialog modal-dialog-centered">
                                                <div class="modal-content">
                                                    <form method="post" asp-page-handler="Eliminar">
                                                        <div class="modal-header">
                                                            <h5 class="modal-title">Confirmar eliminación</h5>

                                                            <button type="button"
                                                                    class="btn-close"
                                                                    data-bs-dismiss="modal"
                                                                    aria-label="Cerrar">
                                                            </button>
                                                        </div>

                                                        <div class="modal-body">
                                                            <input type="hidden" name="ProveedorId" value="@proveedor.ProveedorId">

                                                            <p>
                                                                ¿Seguro que deseas eliminar este proveedor?
                                                            </p>

                                                            <p>
                                                                <strong>@proveedor.Nombre</strong>
                                                            </p>

                                                            <p class="text-danger mb-0">
                                                                Si el proveedor tiene productos o pedidos registrados,
                                                                no se eliminará directamente.
                                                            </p>
                                                        </div>

                                                        <div class="modal-footer">
                                                            <button type="button"
                                                                    class="btn btn-secondary"
                                                                    data-bs-dismiss="modal">
                                                                Cancelar
                                                            </button>

                                                            <button type="submit" class="btn btn-danger">
                                                                Sí, borrar
                                                            </button>
                                                        </div>
                                                    </form>
                                                </div>
                                            </div>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

@if (!string.IsNullOrWhiteSpace(Model.ProveedorIdDesactivar))
{
    <div class="modal fade"
         id="modalDesactivarProveedor"
         tabindex="-1"
         data-bs-backdrop="static"
         data-auto-open="true">

        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <form method="post" asp-page-handler="Desactivar">
                    <div class="modal-header bg-warning text-dark">
                        <h5 class="modal-title">No se puede eliminar el proveedor</h5>

                        <button type="button"
                                class="btn-close"
                                data-bs-dismiss="modal"
                                aria-label="Cerrar">
                        </button>
                    </div>

                    <div class="modal-body">
                        <input type="hidden" name="ProveedorId" value="@Model.ProveedorIdDesactivar">

                        <p>
                            <strong>Proveedor:</strong> @Model.NombreProveedorDesactivar
                        </p>

                        <p>
                            @Model.MensajeDesactivar
                        </p>

                        <p class="text-danger fw-bold mb-0">
                            ¿Deseas desactivarlo en su lugar?
                        </p>
                    </div>

                    <div class="modal-footer">
                        <button type="button"
                                class="btn btn-secondary"
                                data-bs-dismiss="modal">
                            Cancelar
                        </button>

                        <button type="submit" class="btn btn-danger">
                            Sí, desactivar
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
}

@if (!string.IsNullOrWhiteSpace(Model.Mensaje))
{
    <div class="modal fade" id="modalMensaje" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">

                <div class="modal-header bg-@Model.TipoMensaje text-white">
                    <h5 class="modal-title">@Model.TituloMensaje</h5>

                    <button type="button"
                            class="btn-close"
                            data-bs-dismiss="modal"
                            aria-label="Cerrar">
                    </button>
                </div>

                <div class="modal-body">
                    <p class="mb-0">@Model.Mensaje</p>
                </div>

                <div class="modal-footer">
                    <button type="button"
                            class="btn btn-secondary"
                            data-bs-dismiss="modal">
                        Aceptar
                    </button>
                </div>

            </div>
        </div>
    </div>
}