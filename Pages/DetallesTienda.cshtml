@page
@using Proyecto.Models
@model DetallesTiendaModel
@{
    ViewData["Title"] = "Administrar tiendas";
}
<div class="estilo-tiendas">
    
    <ul class="nav menu">
        <li class="nav-item">
            <button class="nav-link" data-bs-toggle="modal" data-bs-target="#modal-sesion"><img class="cuenta-busqueda" src="/img/usuarioIcono2.png" alt=""></button>
            <div class="modal" tabindex="-1" id="modal-sesion">
                <div class="modal-dialog">
                    <div class="modal-content">
                        <div class="modal-header">
                            <h5 class="modal-title">Informacion de Usuario</h5>
                            <button type="button" class="btn-close" data-bs-dismiss="modal"
                                    aria-label="Close"></button>
                        </div>
                        <div class="modal-body">
                            @if(Model.UsuarioActual != null){
                                <p>Nombre: @Model.UsuarioActual.Nombre</p>
                                <p>Telefono: @Model.UsuarioActual.Telefono</p>
                                <p>Rol: @Model.UsuarioActual.Rol</p>
                            }
                        </div>
                        <div class="modal-footer">
                            <button type="button" class="btn btn-secondary"
                                    data-bs-dismiss="modal">Aceptar</button>
                            <a asp-page="/Index" class="btn btn-primary">Cerrar sesion</a>
                        </div>
                    </div>
                </div>
            </div>
        </li>
        <li class="nav-item">
            <a class="nav-link" asp-page="/Administrador"><img title="Dashboard" class="img-menu" src="/img/dashboard.svg" alt=""></a>
        </li>
        <li class="nav-item">
            <a class="nav-link" asp-page="/Inventario"><img title="Inventario" class = "img-menu" src="/img/barcode-solid.svg" alt=""></a>
        </li>
        <li class="nav-item">
            <a class="nav-link seleccionado" asp-page="/Tiendas"><img title="Tiendas" class="img-menu" src="/img/store.svg" alt=""></a>
        </li>
        <li class="nav-item">
            <a class="nav-link" asp-page="/Historial"><img title="Historial" class="img-menu" src="/img/historial.svg" alt=""></a>
        </li>
    </ul>
    <div class="tiendas detalles-tienda">
        <div class="encabezado">
            <div class="fila-titulo">
                <div class="regreso">
                    <a asp-page="/Tiendas" class="btn-regreso"><img src="/img/arrow-left-solid.svg" alt=""></a>
                </div>
                <div class="titulo">
                    Inventario de la tienda:
                    @if(Model.TiendaActual != null){
                        @Model.TiendaActual.Nombre;
                    }
                    </div>
            </div>
            <div class="fila">
                <form method="postBusqueda" class="busqueda">
                    <input class="barra-busqueda" type="text" placeholder="Buscar por nombre o codigo">
                    <button type="submit" class="btn-busqueda-lupa"><img src="/img/lupa.png" alt="" class="img-lupa"></button>
                </form>
                <div class="info-encabezado">
                    <a class="elemento-info-encabezado" asp-page="/Pedidos">Historial de pedidos<img class="btn-inventario" src="/img/historial.svg" alt=""></a>
                    <button class="elemento-info-encabezado" data-bs-toggle="modal" data-bs-target="#modal-registrar-pedido">Registrar pedido<img class="btn-inventario"src="/img/agregar.svg" alt=""></button>
                    <div class="modal" tabindex="-1" id="modal-registrar-pedido" data-bs-backdrop="static">
                        <div class="modal-dialog">
                            <div class="modal-content">
                                <form method="post" id="RegistrarPedido" asp-page-handler="RegistrarPedido">
                                    <div class="modal-header">
                                        <h5 class="modal-title">Nuevo pedido</h5>
                                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                                    </div>
                                    <div class="modal-body">
                                        <!--Ingresar datos-->
                                        <div class="info-tienda">
                                            Proveedor: <select name="ProveedorId" class="form-control form-select" id="proveedorId" required>
                                                <option value="" selected disabled>Seleccione un proveedor</option>
                                                @foreach(var proveedor in Model.Proveedores){
                                                    <option value="@proveedor.ProveedorId">
                                                        @proveedor.Nombre
                                                    </option>
                                                }
                                            </select>
                                        </div>
                                        <div class="info-tienda">
                                            Fecha: <input type="date" class="form-control" id="fecha" value="@DateTime.Now.ToString("yyyy-MM-dd")" readonly>
                                        </div>
                                        <div class="cont-pedido" id="productosPedido">
                                            <div class="producto-pedido">
                                                <div class="info-tienda">
                                                    Producto:
                                                    <select name="ProductoIds" class="form-control form-select" required onchange="actualizarProductos()">
                                                        <option value="" selected disabled>Seleccione un producto</option>
                                                        @foreach (var producto in Model.Productos)
                                                        {
                                                            <option value="@producto.ProductoId">
                                                                @producto.Nombre
                                                            </option>
                                                        }
                                                    </select>
                                                </div>
                                                <div class="info-tienda">
                                                    Cantidad:
                                                    <input type="number" class="form-control"
                                                        name="Cantidades"
                                                        min="1"
                                                        required
                                                        oninput="calcularTotal()">
                                                </div>
                                                <div class="info-tienda">
                                                    Costo unitario:
                                                    <input type="number" class="form-control"
                                                        name="CostosUnitarios"
                                                        min="0.01"
                                                        step="0.01"
                                                        required
                                                        oninput="calcularTotal()">
                                                </div>
                                                <button type="button" class="btn-eliminar-producto" onclick="eliminarProducto(this)">Eliminar producto</button>
                                            </div>
                                        </div>
                                        <div class="info-tienda">
                                            Total: <input type="text" class="form-control" id="montoTotal" readonly value="$0.00">
                                        </div>
                                        <button type="button" class="btn btn-secondary" onclick="agregarProducto()">
                                            Agregar otro producto
                                        </button>
                                    </div>
                                    <div class="modal-footer">
                                        <button type="button" class="btn btn-secondary"
                                                data-bs-dismiss="modal">Cancelar</button>
                                        <button type="submit" class="btn btn-primary" >Registrar pedido</button>
                                    </div>
                                </form>
                            </div>
                        </div>
                    </div>
                </div>
                
            </div>
        </div>
        <div class="detalles">
            <div class="contenedor-tabla-detalles">
                <table class="table table-dark table-striped tabla-dinamica">
                    <thead>
                        <tr>
                            <th scope="col">Nombre</th>
                            <th scope="col">Codigo</th>
                            <th scope="col">Cantidad</th>
                            <th scope="col">Precio</th>
                            <th scope="col">Categoria</th>
                            <th scope="col" class="no-ordenar ajustar"></th>
                        </tr>
                    </thead>
                    <tbody>
                        @if(Model.Inventarios != null){
                            @foreach(var inventario in Model.Inventarios){
                            <tr>
                                <td>@inventario.Producto.Nombre</td>
                                <td>@inventario.Producto.Codigo <span class="invisible">codigo</span></td>
                                <td>@inventario.Stock<span class="invisible">cantidad</span></td>
                                <td>$@inventario.Producto.Precio<span class="invisible">precio</span></td>
                                <td>
                                    @if(inventario.Producto.Categoria != null){
                                        @inventario.Producto.Categoria.Nombre
                                    }
                                </td>
                                <td>
                                    <button class="btn-detalles-tienda" data-bs-toggle="modal" data-bs-target="#modal-reducir-stock-@inventario.InventarioId">Reducir Stock<img class="btn-inventario"src="/img/circle-minus.svg" alt=""></button>
                                    <div class="modal" tabindex="-1" id="modal-reducir-stock-@inventario.InventarioId" data-bs-backdrop="static">
                                        <div class="modal-dialog">
                                            <div class="modal-content">
                                                <form method="post" id="ReduccionDeStock" asp-page-handler="ReducirStock">
                                                    <div class="modal-header">
                                                        <h5 class="modal-title">Reduccion de stock</h5>
                                                        <button type="button" class="btn-close" data-bs-dismiss="modal"
                                                                aria-label="Close"></button>
                                                    </div>
                                                    <div class="modal-body">
                                                        <!--Ingresar datos-->
                                                        <input type="hidden" name="InventarioId" value="@inventario.InventarioId">
                                                        <div class="info-tienda">
                                                            Id: <input type="text" class="form-control" id="productoId" disabled value="@inventario.Producto.ProductoId">
                                                        </div>
                                                        <div class="info-tienda">
                                                            Nombre: <input type="text" class="form-control" id="nombre" disabled value="@inventario.Producto.Nombre">
                                                        </div>
                                                        <div class="info-tienda">
                                                            Codigo: <input type="text" class="form-control" id="codigo" disabled value="@inventario.Producto.Codigo">
                                                        </div>
                                                        <div class="info-tienda">
                                                            Cantidad: <input type="number" class="form-control" id="categoria" min="1" max="@inventario.Stock" required name="Cantidad">
                                                        </div>
                                                        <div class="info-tienda">
                                                            Razon de la reduccion: <input type="text" class="form-control" maxlength="100" id="precio" required name="Motivo">
                                                        </div>
                                                    </div>
                                                    <div class="modal-footer">
                                                        <button type="button" class="btn btn-secondary"
                                                                data-bs-dismiss="modal">Cancelar</button>
                                                        <button type="submit" class="btn btn-primary">Guardar Cambios</button>
                                                    </div>
                                                </form>
                                            </div>
                                        </div>
                                    </div>
                                </td>
                            </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@if (!string.IsNullOrWhiteSpace(Model.Mensaje))
{
    <div class="modal fade" id="modalMensaje" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">

                <div class="modal-header bg-@Model.TipoMensaje text-white">
                    <h5 class="modal-title">@Model.TituloMensaje</h5>

                    <button type="button"
                            class="btn-close"
                            data-bs-dismiss="modal"
                            aria-label="Cerrar">
                    </button>
                </div>

                <div class="modal-body">
                    <p class="mb-0">@Model.Mensaje</p>
                </div>

                <div class="modal-footer">
                    <button type="button"
                            class="btn btn-secondary"
                            data-bs-dismiss="modal">
                        Aceptar
                    </button>
                </div>

            </div>
        </div>
    </div>
}