@page
@using Proyecto.Models
@model TiendasModel
@{
    ViewData["Title"] = "Tiendas";
}
<div class="estilo-tiendas">
    
    <ul class="nav menu">
        <li class="nav-item">
            <button class="nav-link" data-bs-toggle="modal" data-bs-target="#modal-sesion"><img class="cuenta-busqueda" src="/img/usuarioIcono2.png" alt=""></button>
            <div class="modal" tabindex="-1" id="modal-sesion">
                <div class="modal-dialog">
                    <div class="modal-content">
                        <div class="modal-header">
                            <h5 class="modal-title">Informacion de Usuario</h5>
                            <button type="button" class="btn-close" data-bs-dismiss="modal"
                                    aria-label="Close"></button>
                        </div>
                        <div class="modal-body">
                            @if(Model.UsuarioActual != null){
                                <p>Nombre: @Model.UsuarioActual.Nombre</p>
                                <p>Telefono: @Model.UsuarioActual.Telefono</p>
                                <p>Rol: @Model.UsuarioActual.Rol</p>
                            }
                        </div>
                        <div class="modal-footer">
                            <button type="button" class="btn btn-secondary"
                                    data-bs-dismiss="modal">Aceptar</button>
                            <a asp-page="/Index" class="btn btn-primary">Cerrar sesion</a>
                        </div>
                    </div>
                </div>
            </div>
        </li>
        <li class="nav-item">
            <a class="nav-link" asp-page="/Administrador"><img title="Dashboard" class="img-menu" src="/img/dashboard.svg" alt=""></a>
        </li>
        <li class="nav-item">
            <a class="nav-link" asp-page="/Inventario"><img title="Inventario" class = "img-menu" src="/img/barcode-solid.svg" alt=""></a>
        </li>
        <li class="nav-item">
            <a class="nav-link seleccionado" asp-page="/Tiendas"><img title="Tiendas" class="img-menu" src="/img/store.svg" alt=""></a>
        </li>
        <li class="nav-item">
            <a class="nav-link" asp-page="/Historial"><img title="Historial" class="img-menu" src="/img/historial.svg" alt=""></a>
        </li>
    </ul>
    <div class="tiendas">
        <div class="encabezado">
            <div class="fila">
                <div class="titulo">Tiendas</div>
            </div>
            <div class="fila">
                <form method="post" asp-page-handler="Busqueda" class="busqueda">
                    <input class="barra-busqueda" type="text" placeholder="Buscar por nombre o direccion" name="ParametroDeBusqueda" value="@Model.ParametroDeBusqueda">
                    <button type="submit" class="btn-busqueda-lupa"><img src="/img/lupa.png" alt="" class="img-lupa"></button>
                </form>
                <div class="info-encabezado">
                    <button class="elemento-info-encabezado" data-bs-toggle="modal" data-bs-target="#modal-tienda">Nueva tienda<img class="btn-inventario" src="/img/agregar.svg" alt=""></button>
                    <div class="modal" tabindex="-1" id="modal-tienda" data-bs-backdrop="static">
                        <div class="modal-dialog">
                            <form method="post" asp-page-handler="Registrar">
                                <div class="modal-content">
                                    <div class="modal-header">
                                        <h5 class="modal-title">Ingrese la informacion de la tienda</h5>
                                        
                                    </div>
                                    <div class="modal-body">
                                        <!--Ingresar datos-->
                                        <div class="info-tienda">
                                            Nombre de la tienda: <input type="text" name="Nombre" id="nombre" class="form-control" maxlength="50" required>
                                        </div>
                                        <div class="info-tienda">
                                            Direccion de la tienda: <input type="text" name="Direccion" id="direccion" class="form-control" maxlength="50" required>
                                        </div>
                                    </div>
                                    <div class="modal-footer">
                                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                                        <button type="submit" class="btn btn-primary">Registrar nueva tienda</button>
                                    </div>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="tablas">
            <div class="contenedor-tabla">
                <div class="tabla-productos">
                    <table class="table table-dark table-striped tabla-dinamica">
                        <thead>
                            <tr>
                                <th scope="col">Nombre</th>
                                <th scope="col">Direccion</th>
                                <th scope="col">Estado</th>
                                <th scope="col">Ventas de hoy</th>
                                <th scope="col" class="no-ordenar"></th>
                                <th scope="col" class="no-ordenar"></th>
                                <th scope="col" class="no-ordenar"></th>
                            </tr>
                        </thead>
                        <tbody>
                            @for (int i = 0; i < Model.Tiendas.Count; i++)
                            {
                                
                                <tr>
                                    <td>@Model.Tiendas[i].Nombre</td>
                                    <td>@Model.Tiendas[i].Direccion</td>
                                    <td>
                                        @if (Model.Tiendas[i].Estado == true)
                                        {
                                            @:Activo
                                        }
                                        else
                                        {
                                            @:Inactivo
                                        }
                                    </td>
                                    <td>@Model.Tiendas[i].VentaTotal.ToString("C") <span class="invisible">pesos</span></td>
                                    <td><a asp-page-handler="AbrirInventario" asp-route-id="@Model.Tiendas[i].TiendaId" class="btn-detalles-tienda">Inventario</a></td>
                                    <td><a asp-page-handler="AbrirEmpleados" asp-route-id="@Model.Tiendas[i].TiendaId" class="btn-detalles-tienda">Empleados</a></td>
                                    <td>
                                        <button class="btn-detalles-tienda" data-bs-toggle="modal" data-bs-target="#modal-editar-@Model.Tiendas[i].TiendaId">Editar<img class="btn-inventario" src="/img/editar.svg" alt=""></button>
                                        <div class="modal" tabindex="-1" id="modal-editar-@Model.Tiendas[i].TiendaId" data-bs-backdrop="static">
                                            <div class="modal-dialog">
                                                <form method="post" asp-page-handler="Editar">
                                                    <div class="modal-content">
                                                        <div class="modal-header">
                                                            <h5 class="modal-title">Informacion de la tienda</h5>
                                                            
                                                        </div>
                                                        <div class="modal-body">
                                                            <!--Ingresar datos-->
                                                            <input type="hidden" name="TiendaId" value="@Model.Tiendas[i].TiendaId">
                                                            <div class="info-tienda">
                                                                Id: <input type="number" value="@Model.Tiendas[i].TiendaId" id="nombre" class="form-control" disabled>
                                                            </div>
                                                            <div class="info-tienda">
                                                                Nombre: <input type="text" value="@Model.Tiendas[i].Nombre" name="Nombre" id="nombre" class="form-control" maxlength="50" required>
                                                            </div>
                                                            <div class="info-tienda">
                                                                Direccion: <input type="text" value="@Model.Tiendas[i].Direccion" name="Direccion" id="direccion" class="form-control" maxlength="50" required>
                                                            </div>
                                                        </div>
                                                        <div class="modal-footer">
                                                            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                                                            <button type="button" class="btn btn-danger" data-bs-toggle="modal" data-bs-target="#modal-confirmar-eliminar-@Model.Tiendas[i].TiendaId">Borrar
                                                            </button>
                                                            <button type="submit" class="btn btn-primary">Guardar cambios</button>
                                                        </div>
                                                    </div>
                                                </form>
                                            </div>
                                        </div>
                                        <div class="modal fade" id="modal-confirmar-eliminar-@Model.Tiendas[i].TiendaId" tabindex="-1">
                                            <div class="modal-dialog modal-dialog-centered">
                                                <div class="modal-content">

                                                    <div class="modal-header">
                                                        <h5 class="modal-title">Confirmar eliminación</h5>
                                                        <button type="button" class="btn-close" data-bs-dismiss="modal"
                                                                aria-label="Cerrar"></button>
                                                    </div>

                                                    <div class="modal-body">
                                                        <p>
                                                            ¿Seguro que deseas eliminar esta tienda?
                                                        </p>
                                                        <p>
                                                            <strong>@Model.Tiendas[i].Nombre</strong>
                                                        </p>
                                                        <p class="text-danger mb-0">
                                                            Esta acción no se puede deshacer
                                                        </p>
                                                    </div>

                                                    <div class="modal-footer">
                                                        <button type="button"
                                                                class="btn btn-secondary"
                                                                data-bs-dismiss="modal">
                                                            Cancelar
                                                        </button>

                                                        <form method="post" asp-page-handler="Eliminar">
                                                            <input type="hidden" name="id" value="@Model.Tiendas[i].TiendaId" />

                                                            <button type="submit" class="btn btn-danger">
                                                                Sí, borrar
                                                            </button>
                                                        </form>
                                                    </div>

                                                </div>
                                            </div>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>