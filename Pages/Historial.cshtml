@page
@model HistorialModel
@{
    ViewData["Title"] = "Historial";
}

<div class="estilo-historial">

    <ul class="nav menu">
        <li class="nav-item">
            <button class="nav-link" data-bs-toggle="modal" data-bs-target="#modal-sesion">
                <img class="cuenta-busqueda" src="/img/usuarioIcono2.png" alt="">
            </button>

            <div class="modal" tabindex="-1" id="modal-sesion">
                <div class="modal-dialog">
                    <div class="modal-content">
                        <div class="modal-header">
                            <h5 class="modal-title">Informacion de Usuario</h5>
                            <button type="button" class="btn-close" data-bs-dismiss="modal"
                                    aria-label="Close"></button>
                        </div>

                        <div class="modal-body">
                            @if (Model.UsuarioActual != null)
                            {
                                <p>Nombre: @Model.UsuarioActual.Nombre</p>
                                <p>Telefono: @Model.UsuarioActual.Telefono</p>
                                <p>Rol: @Model.UsuarioActual.Rol</p>
                            }
                        </div>

                        <div class="modal-footer">
                            <button type="button" class="btn btn-secondary"
                                    data-bs-dismiss="modal">
                                Aceptar
                            </button>

                            <a asp-page="/Index" asp-page-handler="CerrarSesion" class="btn btn-primary">
                                Cerrar sesion
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </li>

        <li class="nav-item">
            <a class="nav-link" asp-page="/Administrador">
                <img title="Dashboard" class="img-menu" src="/img/dashboard.svg" alt="">
            </a>
        </li>

        <li class="nav-item">
            <a class="nav-link" asp-page="/Inventario">
                <img title="Inventario" class="img-menu" src="/img/barcode-solid.svg" alt="">
            </a>
        </li>

        <li class="nav-item">
            <a class="nav-link" asp-page="/Tiendas">
                <img title="Tiendas" class="img-menu" src="/img/store.svg" alt="">
            </a>
        </li>

        <li class="nav-item">
            <a class="nav-link seleccionado" asp-page="/Historial">
                <img title="Historial" class="img-menu" src="/img/historial.svg" alt="">
            </a>
        </li>
    </ul>

    <div class="historial">
        <div class="encabezado">
            <div class="fila">
                <div class="titulo">Historial de ventas</div>
            </div>

            <div class="fila">
                <form method="post" asp-page-handler="Busqueda" class="busqueda completo">
                    <input class="barra-busqueda"
                           type="text"
                           placeholder="Buscar por venta, usuario, tienda o producto"
                           name="ParametroDeBusqueda"
                           value="@Model.ParametroDeBusqueda">

                    <button type="submit" class="btn-busqueda-lupa">
                        <img src="/img/lupa.png" alt="" class="img-lupa">
                    </button>
                </form>

                <div class="info-encabezado">
                    <a class="elemento-info-encabezado" asp-page="/CortesCaja">
                        Historial de cortes de caja
                        <img class="btn-inventario" src="/img/historial.svg" alt="">
                    </a>
                    <a class="elemento-info-encabezado" asp-page="/HistorialMovimiento">
                        Historial de movimientos
                        <img class="btn-inventario" src="/img/historial.svg" alt="">
                    </a>
                </div>
            </div>
        </div>

        <div class="tablas">
            <div class="contenedor-tabla-historial">
                <div class="tabla-ventas orden-correcto">
                    <table class="table table-dark table-striped tabla-mayor-menor" data-empty="No se encontraron ventas">
                        <thead>
                            <tr>
                                <th scope="col">Codigo</th>
                                <th scope="col">Usuario</th>
                                <th scope="col">Tienda</th>
                                <th scope="col">Fecha</th>
                                <th scope="col">Total</th>
                                <th scope="col" class="no-ordenar"></th>
                            </tr>
                        </thead>

                        <tbody>
                            @for (int i = 0; i < Model.Ventas.Count; i++)
                            {
                                <tr>
                                    <td>@Model.Ventas[i].VentaId</td>
                                    <td>@Model.Ventas[i].Usuario</td>
                                    <td>@Model.Ventas[i].Tienda</td>

                                    <td data-order="@Model.Ventas[i].Fecha.ToString("yyyy-MM-dd HH:mm:ss")">
                                        @Model.Ventas[i].Fecha.ToString("dd/MM/yyyy HH:mm")
                                    </td>

                                    <td>@Model.Ventas[i].Total.ToString("C")</td>

                                    <td>
                                        <button type="button"
                                                class="btn-detalles-tienda"
                                                data-bs-toggle="modal"
                                                data-bs-target="#modal-detalles-venta-@Model.Ventas[i].VentaId">
                                            Detalles
                                            <img class="btn-inventario" src="/img/circle-info.svg" alt="">
                                        </button>

                                        <div class="modal" tabindex="-1" id="modal-detalles-venta-@Model.Ventas[i].VentaId" data-bs-backdrop="static">
                                            <div class="modal-dialog">
                                                <div class="modal-content">
                                                    <div class="modal-header">
                                                        <h5 class="modal-title">Informacion de la venta</h5>

                                                        <button type="button"
                                                                class="btn-close"
                                                                data-bs-dismiss="modal"
                                                                aria-label="Close">
                                                        </button>
                                                    </div>

                                                    <div class="modal-body">
                                                        <div class="info-tienda">
                                                            Usuario:
                                                            <input type="text"
                                                                   class="form-control"
                                                                   disabled
                                                                   value="@Model.Ventas[i].Usuario">
                                                        </div>

                                                        <div class="info-tienda">
                                                            Tienda:
                                                            <input type="text"
                                                                   class="form-control"
                                                                   disabled
                                                                   value="@Model.Ventas[i].Tienda">
                                                        </div>

                                                        <div class="info-tienda">
                                                            Fecha:
                                                            <input type="text"
                                                                   class="form-control"
                                                                   disabled
                                                                   value="@Model.Ventas[i].Fecha.ToString("dd/MM/yyyy HH:mm")">
                                                        </div>

                                                        @foreach (var detalle in Model.Ventas[i].Detalles)
                                                        {
                                                            <div class="producto-venta">
                                                                <div class="info-tienda">
                                                                    Producto:
                                                                    <input type="text"
                                                                           class="form-control"
                                                                           disabled
                                                                           value="@(detalle.Producto?.Nombre ?? "Sin producto")">
                                                                </div>

                                                                <div class="info-tienda">
                                                                    Cantidad:
                                                                    <input type="text"
                                                                           class="form-control"
                                                                           disabled
                                                                           value="@detalle.Cantidad">
                                                                </div>

                                                                <div class="info-tienda">
                                                                    Subtotal:
                                                                    <input type="text"
                                                                           class="form-control"
                                                                           disabled
                                                                           value="@((detalle.Subtotal ?? 0).ToString("C"))">
                                                                </div>
                                                            </div>
                                                        }
                                                        @foreach(var pago in Model.Ventas[i].Pagos){
                                                            <div class="info-tienda">
                                                                @pago.Metodo:
                                                                <input type="text"
                                                                        class="form-control"
                                                                        disabled
                                                                        value="@pago.Monto.ToString("C")">
                                                            </div>
                                                        }

                                                        <div class="info-tienda">
                                                            Total:
                                                            <input type="text"
                                                                   class="form-control"
                                                                   disabled
                                                                   value="@Model.Ventas[i].Total.ToString("C")">
                                                        </div>
                                                    </div>

                                                    <div class="modal-footer">
                                                        <button type="button" class="btn btn-primary" data-bs-dismiss="modal">
                                                            Aceptar
                                                        </button>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>