@page
@using Proyecto.Models
@model AdministradorModel
@{
    ViewData["Title"] = "Administrador";
}
<!--ya no se usa el menú de navegación ni el pie de página, por lo que se han comentado en el archivo _Layout.cshtml-->
<div class="estilo-administrador">
    <ul class="nav menu">
        <li class="nav-item">
            <button class="nav-link" data-bs-toggle="modal" data-bs-target="#modal-sesion"><img class="cuenta-busqueda" src="/img/usuarioIcono2.png" alt=""></button>
            <div class="modal" tabindex="-1" id="modal-sesion">
                <div class="modal-dialog">
                    <div class="modal-content">
                        <div class="modal-header">
                            <h5 class="modal-title">Informacion de Usuario</h5>
                            <button type="button" class="btn-close" data-bs-dismiss="modal"
                                    aria-label="Close"></button>
                        </div>
                        <div class="modal-body">
                            @if(Model.UsuarioActual != null){
                                <p>Nombre: @Model.UsuarioActual.Nombre</p>
                                <p>Telefono: @Model.UsuarioActual.Telefono</p>
                                <p>Rol: @Model.UsuarioActual.Rol</p>
                            }
                        </div>
                        <div class="modal-footer">
                            <button type="button" class="btn btn-secondary"
                                    data-bs-dismiss="modal">Aceptar</button>
                            <a asp-page="/Index" class="btn btn-primary">Cerrar sesion</a>
                        </div>
                    </div>
                </div>
            </div>
        </li>
        <li class="nav-item">
            <a class="nav-link seleccionado" asp-page="/Administrador"><img title="Dashboard" class="img-menu" src="/img/dashboard.svg" alt=""></a>
        </li>
        <li class="nav-item">
            <a class="nav-link" asp-page="/Inventario"><img title="Inventario" class = "img-menu" src="/img/barcode-solid.svg" alt=""></a>
        </li>
        <li class="nav-item">
            <a class="nav-link" asp-page="/Tiendas"><img title="Tiendas" class="img-menu" src="/img/store.svg" alt=""></a>
        </li>
        <li class="nav-item">
            <a class="nav-link" asp-page="/Historial"><img title="Historial" class="img-menu" src="/img/historial.svg" alt=""></a>
        </li>
    </ul>
    <div class="dashboard">
        <!-- Primera fila -->
        <div class="filas">
            <div class="card" onclick="location.href='@Url.Page("/Historial")';">
                <div class="card-body">
                    <h5 class="card-title">Ventas hoy</h5>
                    <p class="card-text display-6">$12,450.75</p>
                    <p class="card-text">+8.4% respecto a ayer</p>
                </div>
            </div>

            <div class="card">
                <div class="card-body">
                    <h5 class="card-title">Productos en stock</h5>
                    <p class="card-text display-6">1,248</p>
                    <p class="card-text">37 productos con stock bajo</p>
                </div>
            </div>

            <div class="card" style="width: 18rem;">
                <div class="card-body">
                    <h5 class="card-title">Tienda con mas ventas del mes</h5>
                    <p class="card-text display-6">1,245 ventas</p>
                    <p class="card-text">Tienda Centro</p>

                </div>
            </div>

            <div class="card">
                <div class="card-body">
                    <h5 class="card-title">Venta promedio</h5>
                    <p class="card-text display-6">$66.94</p>
                    <p class="card-text">5.2 artículos por ticket</p>
                </div>
            </div>
        </div>

        <!-- Segunda fila -->
        <div class="filas">
            <div class="card" onclick="location.href='';">
                <div class="card-body">
                    <h5 class="card-title">Ventas por categoría</h5>
                    <p class="card-text">Abarrotes: 42%</p>
                    <p class="card-text">Bebidas: 28%</p>
                    <p class="card-text">Limpieza: 18%</p>
                    <p class="card-text">Otros: 12%</p>
                </div>
            </div>

            <div class="card">
                <div class="card-body">
                    <h5 class="card-title">Alertas de stock</h5>
                    <p class="card-text">⚠️ Coca-Cola 600 ml: 4 unidades</p>
                    <p class="card-text">⚠️ Arroz 1 kg: 2 unidades</p>
                    <p class="card-text">⚠️ Papel higiénico: 1 unidad</p>
                    <p class="card-text">⚠️ Jabón en polvo: agotado</p>
                </div>
            </div>
        </div>

        <!-- Tercera fila -->
        <div class="filas">
            <div class="card">
                <div class="card-body">
                    <h5 class="card-title">Últimas ventas del día</h5>
                    <p class="card-text">14:35 - Ticket #0186 - $124.50</p>
                    <p class="card-text">14:29 - Ticket #0185 - $58.00</p>
                    <p class="card-text">14:22 - Ticket #0184 - $340.90</p>
                    <p class="card-text">14:15 - Ticket #0183 - $79.50</p>
                    <p class="card-text">14:08 - Ticket #0182 - $212.00</p>
                </div>
            </div>
        </div>
    </div>
</div>
